FROM lukemathwalker/cargo-chef:0.1.77-rust-1.95-bookworm AS chef
WORKDIR /build

FROM chef AS planner
COPY Cargo.toml Cargo.lock ./
COPY build.rs ./
COPY migrations ./migrations
COPY src ./src
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
COPY --from=planner /build/recipe.json recipe.json
RUN cargo chef cook --release --locked --recipe-path recipe.json
COPY Cargo.toml Cargo.lock build.rs ./
COPY migrations ./migrations
COPY src ./src
RUN cargo build --release --locked

FROM chef AS test
COPY --from=planner /build/recipe.json recipe.json
RUN cargo chef cook --locked --recipe-path recipe.json
COPY Cargo.toml Cargo.lock build.rs ./
COPY migrations ./migrations
COPY src ./src
RUN cargo test --locked --all-targets

FROM debian:bookworm-slim AS runtime
RUN apt-get update \
    && apt-get install --no-install-recommends -y ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system sillybot \
    && useradd --system --gid sillybot --home-dir /var/lib/sillybot sillybot \
    && install -d -o sillybot -g sillybot /var/lib/sillybot

COPY --from=builder /build/target/release/sillybot /usr/local/bin/sillybot

USER sillybot:sillybot
VOLUME ["/var/lib/sillybot"]
ENTRYPOINT ["/usr/local/bin/sillybot"]
